# Copy to .env and edit. PORT-related vars are mandatory for the chat
# microservice to listen; other vars have sensible defaults.

# Listening ports
PORT=8081
CHAT_PORT=8081
CHAT_HTTPS_PORT=8444
USE_HTTPS=true

# URLs (no trailing slash)
CLIENT_URL=https://localhost:3443
MAIN_SERVER_URL=https://127.0.0.1:8443
SERVER_HOST=localhost
NODE_ENV=development

# Optional: absolute or relative path for the JSON file that holds the
# in-memory ban / timeout state across restarts. Defaults to
# ./moderation_data.json next to chat-service/index.js. Useful for
# deploys that want state outside the repo or tests that want a fixture
# path.
# MODERATION_STORE_PATH=/var/lib/onestreamer/chat/moderation_data.json
