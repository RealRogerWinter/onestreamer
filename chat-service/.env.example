# Copy to .env and edit. PORT-related vars are mandatory for the chat
# microservice to listen; other vars have sensible defaults.

# Listening ports
PORT=8081
CHAT_PORT=8081
CHAT_HTTPS_PORT=8444
USE_HTTPS=true

# URLs (no trailing slash)
CLIENT_URL=https://localhost:3443
MAIN_SERVER_URL=https://127.0.0.1:8443
SERVER_HOST=localhost
NODE_ENV=development

# Shared service-to-service secret (must match the main server's value).
# Used in BOTH directions: chat-service attaches it as X-Internal-Secret on
# its calls to the main server (stream-control routes), and the main server
# attaches it on its calls to THIS service's HTTP API (/api/ban, /api/unban,
# /api/timeout, /api/remove-timeout, /api/system-message, /api/moderation,
# /api/chat-history — see api/internalAuth.js). Generate with:
# openssl rand -base64 48
INTERNAL_API_SECRET=

# Enforcement flag for the chat HTTP API's internal-secret gate (audit CH3).
# Leave unset/false at first: requests without the secret are ALLOWED but
# warn-logged ('ALLOWED (ENFORCE_CHAT_INTERNAL_AUTH off)') so you can verify
# the main server is sending the secret on every call site. Once that log is
# silent, set to true — requests without the secret then get 401. /health is
# never gated.
# ENFORCE_CHAT_INTERNAL_AUTH=true

# Optional: absolute or relative path for the JSON file that holds the
# in-memory ban / timeout state across restarts. Defaults to
# ./moderation_data.json next to chat-service/index.js. Useful for
# deploys that want state outside the repo or tests that want a fixture
# path.
# MODERATION_STORE_PATH=/var/lib/onestreamer/chat/moderation_data.json
