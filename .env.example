# OneStreamer environment template. Copy to `.env` (which is gitignored)
# and fill in real values. The server fails fast at startup if any of the
# secrets marked REQUIRED is missing — there are no source-tree fallbacks.

# --- Process / runtime ---
PORT=3001
NODE_ENV=development
COOLDOWN_SECONDS=30

# --- URL-relay whitelist (ADR-0010) ---
# When set to "true", the server fails to start if WhitelistService can't
# initialize. Without this flag, init failure is a logged warning and the
# URL-relay subsystem degrades to its Phase-0 pass-through (no policy
# enforcement). Recommended for production once the feature is live; leave
# unset on dev hosts where the DB might not be migrated yet.
URL_RELAY_REQUIRE_WHITELIST_SERVICE=false

# --- Secrets (REQUIRED — no defaults) ---
# JWT_SECRET must match between the main server and chat-service.
# Generate with: openssl rand -base64 48
JWT_SECRET=
# SESSION_SECRET signs Express session cookies. Same generation pattern.
SESSION_SECRET=
# TURN_SECRET is the coturn static-auth-secret used to mint time-limited
# TURN credentials. Must match /etc/turnserver.conf's static-auth-secret.
TURN_SECRET=
# TURNSTILE_SECRET_KEY is the Cloudflare Turnstile site secret (server-side
# verification key). Get it from the Cloudflare Turnstile dashboard.
TURNSTILE_SECRET_KEY=
# INTERNAL_API_SECRET is the shared service-to-service secret between the
# main server and the chat-service (must be IDENTICAL on both processes;
# same generation pattern). The main server attaches it as X-Internal-Secret
# on every chat-service HTTP call (server/utils/chatServiceClient.js) and
# verifies it on the stream-control routes; the chat-service does the same
# in reverse (chat-service/api/internalAuth.js, gated by
# ENFORCE_CHAT_INTERNAL_AUTH on the chat-service side — see
# chat-service/.env.example for the rollout sequence).
INTERNAL_API_SECRET=

# --- LiveKit (the sole WebRTC backend — ADR-0024) ---
# LiveKit powers streamer<->viewer streaming, URL-relay ingress, recording
# egress, and transcription. Required in any real deployment (MediaSoup was
# retired). See docs/architecture/adr/0024.
LIVEKIT_HOST=http://127.0.0.1:7882
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=ws://localhost:7882
LIVEKIT_ROOM_NAME=onestreamer-main

# --- Email (SendGrid via SMTP; required if you want verification emails) ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=
FROM_EMAIL=noreply@yourdomain.com

# --- Redis (optional cache) ---
REDIS_URL=redis://localhost:6379

# --- Google OAuth (optional; enables Sign-in with Google) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public IP of the TURN server, sent to clients in ICE config (bypasses Cloudflare).
TURN_PUBLIC_IP=

# --- Database driver (ADR-0014) ---
# better-sqlite3 is the DEFAULT driver since the Phase-C cutover. Opt out
# (revert to node-sqlite3 without a code change) with the exact string:
# USE_BETTER_SQLITE3=false
