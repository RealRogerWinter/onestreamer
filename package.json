{
  "name": "onestreamer",
  "version": "1.0.0",
  "description": "A video streaming service with single streamer takeover functionality",
  "main": "index.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run chat\"",
    "dev-with-chat": "concurrently \"npm run server\" \"npm run client\" \"npm run chat\"",
    "dev-no-chat": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "chat": "cd chat-service && npm run dev",
    "chat-prod": "cd chat-service && npm start",
    "install-all": "npm install && cd client && npm install && cd ../chat-service && npm install",
    "test": "jest --config config/jest/jest.config.js",
    "test:watch": "jest --config config/jest/jest.config.js --watch",
    "test:integration": "jest --config config/jest/jest.integration.config.js",
    "test:bettersqlite": "jest --config config/jest/jest.bettersqlite.config.js",
    "test:all": "npm test && npm run test:bettersqlite && npm run test:integration && cd client && npm test -- --watchAll=false"
  },
  "keywords": [
    "streaming",
    "webrtc",
    "video",
    "realtime"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.966.0",
    "@aws-sdk/s3-request-presigner": "^3.966.0",
    "@livekit/rtc-node": "^0.13.20",
    "@types/dompurify": "^3.2.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "~11.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dompurify": "^3.2.6",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "livekit-client": "^2.15.7",
    "livekit-server-sdk": "^2.13.3",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.11",
    "ollama": "^0.5.17",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^4.6.8",
    "sharp": "^0.34.3",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.8.1",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.0"
  },
  "//overrides": "Pin patched versions of transitive deps to clear trivy HIGH/CRITICAL findings (docker-build scan). Each package resolves to a single version in the tree, so these global overrides are safe. node-tar (6->7, build-time only) is deferred — see .trivyignore.",
  "overrides": {
    "fast-xml-parser": "5.8.0",
    "minimatch": "3.1.5",
    "picomatch": "2.3.2",
    "path-to-regexp": "0.1.13",
    "tar-fs": "2.1.4",
    "socket.io-parser": "4.2.6",
    "jws": "3.2.3",
    "validator": "13.15.22",
    "lodash": "4.18.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "jest": "^29.6.2",
    "jest-junit": "^17.0.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
