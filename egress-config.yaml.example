# TEMPLATE — copy to egress-config.yaml on the deploy host and fill in the real
# LiveKit api_key/api_secret. The real egress-config.yaml is gitignored
# (audit S4/D3): it must never be committed.
# LiveKit Egress Configuration
log_level: info
# Set these to your LiveKit API key/secret (must match the LiveKit server). Do NOT commit real values.
api_key: REPLACE_WITH_LIVEKIT_API_KEY
api_secret: REPLACE_WITH_LIVEKIT_API_SECRET
ws_url: ws://127.0.0.1:7882

# Redis (required for communication with LiveKit server)
redis:
  address: 127.0.0.1:6379

# Health check
health_port: 9090

# Insecure mode (for local dev)
insecure: true

# File output configuration
file_output:
  local:
    - /out

# CPU cost settings
cpu_cost:
  room_composite_cpu_cost: 3.0
  track_composite_cpu_cost: 2.0
  track_cpu_cost: 1.0

# Latency tuning for smoother playback with variable source streams
latency:
  jitter_buffer_latency: 2s       # Buffer for network jitter (default 200ms is too low)
  audio_mixer_latency: 2.75s      # Audio mixing delay
  pipeline_latency: 3s            # Overall pipeline delay
  rtpmaxallowedtsdiff: 5s         # Max RTP timestamp diff before reset
  rtpmaxdriftadjustment: 5ms      # Max drift adjustment per cycle
  old_packet_threshold: 500ms     # Threshold for dropping old packets
