# JWT Secret - Change this in production
JWT_SECRET=***REMOVED-JWT-DEFAULT***

# Google OAuth (Optional)
# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Client URL for OAuth redirects
CLIENT_URL=http://localhost:3000

# Admin Panel Key — required. No fallback in code; the server refuses to
# boot if this is unset. Generate a fresh random value per deploy:
#   openssl rand -hex 32
ADMIN_KEY=

# Redis Configuration (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Session Configuration
SESSION_SECRET=***REMOVED-SESSION-DEFAULT***

# Twitch API Credentials (Required for Random Stream Rotation)
# Get these from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Optional: absolute or repo-relative path to YouTube cookies for
# yt-dlp bot-detection bypass. Defaults to ./youtube-cookies.txt at
# the repo root. See config/youtube-cookies.example.txt for the
# Netscape cookie format.
# YOUTUBE_COOKIES_PATH=/var/lib/onestreamer/youtube-cookies.txt

# Discord live-announcement bot (Optional)
# Posts an announcement card in your Discord whenever a REAL human streamer
# takes over and goes live. URL relay streams and viewbots are NEVER announced.
# Leave both blank to disable (the bot is a no-op when unset). Setup:
#   1. Create an application + bot at https://discord.com/developers/applications
#      and copy the bot token into DISCORD_BOT_TOKEN below.
#   2. Invite the bot to your server (OAuth2 → URL Generator → scopes: bot;
#      bot permissions: View Channel, Send Messages, Embed Links).
#   3. In Discord, enable Developer Mode (Settings → Advanced), then right-click
#      your announcements channel → Copy Channel ID into DISCORD_ANNOUNCE_CHANNEL_ID.
DISCORD_BOT_TOKEN=
DISCORD_ANNOUNCE_CHANNEL_ID=
# Public URL of the site, used for the "Tune in now" link on the announcement
# card. Falls back to CLIENT_URL when unset.
PUBLIC_SITE_URL=
# Re-announce suppression window in ms (default 60000 = 60s). Collapses a burst
# of reconnect retries from a flaky client into one announcement; a genuine new
# go-live after this window is announced again. Set to 0 to announce every
# go-live (no suppression).
# DISCORD_ANNOUNCE_COOLDOWN_MS=60000
