# Uploaded videos (but keep emojis)
uploads/
!uploads/emojis/
!**/uploads/emojis/

# Whisper models (large files)
whisper/models/*.bin
whisper/models/
*.mp4
*.avi
*.mov
*.wmv
*.flv
*.mkv
*.webm
*.m4v
*.mpg
*.mpeg

# Node modules
node_modules/

# Environment variables
.env
.env.local
.env.production.local
.env.development.local
.env.test.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Build directories
dist/
build/
out/

# Temporary files
tmp/
temp/
*.tmp

# Database files
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# Cache
.cache/
.npm/

# Coverage directory
coverage/
*.lcov

# Dependencies
bower_components/

# Production builds
*.min.js
*.min.css
whisper.cpp/

# Data directories
audio-buffers/
egress-recordings/
/clips/

# TLS certificates — per-deploy, never committed; keep the dir + .gitkeep so paths resolve
certificates/*
!certificates/.gitkeep

# Whisper precompiled platform binaries — built/downloaded at install time
whisper/Release/
whisper/*.zip

# Manual editing leftovers (timestamped backups, .old / .bak renames)
**/*.backup*
**/*.old
**/*.bak
**/*~

# Claude Code session/tooling directories (top-level + any subtree)
**/.claude/

# HLS runtime segments written by the live streaming pipeline
public/hls/*.ts
public/hls/*.m3u8

# Runtime state / per-deploy config — checked-in counterparts have .example.* siblings
chat-service/moderation_data.json
server/data/*-state.json
youtube-cookies.txt

# nginx server-block configs are per-deploy; only the .example.conf reference is tracked
nginx/*
!nginx/.gitkeep
!nginx/*.example.conf

# LiveKit per-deploy configs — dormant infrastructure (ADR-0002, ADR-0007),
# only the sanitized livekit-*.example.yaml references are tracked
livekit-config.yaml
livekit-ssl.yaml

# Recording artifacts (keep the .gitkeep scaffolding, ignore actual recordings)
recordings/**
!recordings/**/.gitkeep
videos/**
!videos/.gitkeep
