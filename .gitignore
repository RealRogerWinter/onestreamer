# Uploaded videos (but keep emojis)
uploads/
!uploads/emojis/
!**/uploads/emojis/

# Whisper models (large files)
whisper/models/*.bin
whisper/models/
*.mp4
*.avi
*.mov
*.wmv
*.flv
*.mkv
*.webm
*.m4v
*.mpg
*.mpeg

# Node modules — no trailing slash so a stray `node_modules` *symlink* is
# ignored too (absolute-path symlinks were accidentally committed before).
node_modules

# Environment variables
.env
.env.local
.env.production.local
.env.development.local
.env.test.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Build directories
dist/
build/
out/

# Temporary files
tmp/
temp/
*.tmp

# Database files
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# Cache
.cache/
.npm/

# Coverage directory
coverage/
*.lcov

# Dependencies
bower_components/

# Production builds
*.min.js
*.min.css
whisper.cpp/

# Data directories
audio-buffers/
egress-recordings/
/clips/

# TLS certificates — per-deploy, never committed; keep the dir + .gitkeep so paths resolve
certificates/*
!certificates/.gitkeep

# Whisper precompiled platform binaries — built/downloaded at install time
whisper/Release/
whisper/*.zip

# Manual editing leftovers (timestamped backups, .old / .bak renames)
**/*.backup*
**/*.old
**/*.bak
**/*~

# Claude Code session/tooling directories (top-level + any subtree)
**/.claude/

# HLS runtime segments written by the live streaming pipeline
public/hls/*.ts
public/hls/*.m3u8

# Runtime state / per-deploy config — checked-in counterparts have .example.* siblings
chat-service/moderation_data.json
# Per-install anonymous-identity salt (audit CH5) — runtime secret, sibling
# of the moderation store; also covers .bak/.tmp of the store itself
chat-service/moderation_data.json.*
server/data/*-state.json
youtube-cookies.txt

# nginx server-block configs are per-deploy; only the .example.conf reference is tracked
nginx/*
!nginx/.gitkeep
!nginx/*.example.conf

# LiveKit per-deploy configs — LiveKit is the sole WebRTC backend (ADR-0024)
# and these carry the live api_key/api_secret on a deployed host. Only the
# sanitized *.example siblings are tracked (audit Plan 02 S4 / Plan 03 D3:
# a `git commit -a` must never be able to pick up a secret-bearing config).
livekit-config.yaml
livekit-ssl.yaml
egress-config.yaml
ingress-config.yaml

# Secret-bearing rotation backups (e.g. .env.bak-20260604-rotate,
# egress-config.yaml.bak-20260604-rotate) — same S4/D3 rule
*.bak-*-rotate

# Recording artifacts (keep the .gitkeep scaffolding, ignore actual recordings)
recordings/**
!recordings/**/.gitkeep
videos/**
!videos/.gitkeep
