# LiveKit WebSocket Proxy Configuration
# This proxies WebSocket connections from the public interface to the local LiveKit server

upstream livekit_backend {
    server 127.0.0.1:7880;
}

# Map to handle WebSocket upgrade
map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

server {
    listen 7880 ssl http2;
    listen [::]:7880 ssl http2;
    server_name onestreamer.live;

    # SSL configuration
    ssl_certificate /etc/letsencrypt/live/onestreamer.live/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/onestreamer.live/privkey.pem;
    
    # SSL parameters
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    
    # WebSocket specific settings
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    
    # Timeouts for WebSocket
    proxy_connect_timeout 7d;
    proxy_send_timeout 7d;
    proxy_read_timeout 7d;
    
    # Buffer settings
    proxy_buffering off;
    client_max_body_size 0;
    
    # LiveKit endpoints
    location / {
        proxy_pass http://livekit_backend;
    }
}