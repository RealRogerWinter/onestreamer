+// Transcription endpoints
+app.post('/api/transcription/start', authenticateToken, async (req, res) => {
+  const { streamerId, options } = req.body;
+  const result = await transcriptionService.startTranscription(streamerId, options);
+  res.json(result);
+});
+
+app.post('/api/transcription/stop/:sessionId', authenticateToken, async (req, res) => {
+  const { sessionId } = req.params;
+  const result = await transcriptionService.stopTranscription(sessionId);
+  res.json(result);
+});
+
+app.get('/api/transcription/:sessionId', authenticateToken, async (req, res) => {
+  const { sessionId } = req.params;
+  const transcription = await transcriptionService.getTranscription(sessionId);
+  res.json(transcription);
+});
+
+app.get('/api/transcriptions/active', authenticateToken, async (req, res) => {
+  const activeTranscriptions = await transcriptionService.getActiveTranscriptions();
+  res.json(activeTranscriptions);
+});
+
+app.post('/api/transcription/config', authenticateAdmin, async (req, res) => {
+  const { enable, model, language } = req.body;
+  
+  if (enable !== undefined) {
+    if (enable) {
+      transcriptionService.enableTranscription();
+    } else {
+      transcriptionService.disableTranscription();
+    }
+  }
+  
+  if (model) {
+    transcriptionService.setModel(model);
+  }
+  
+  if (language !== undefined) {
+    transcriptionService.setLanguage(language);
+  }
+  
+  res.json({ success: true, config: transcriptionService.config });
+});
